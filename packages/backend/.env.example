# Backend secrets — set via `supabase secrets set` (prod) or a local .env (never committed).
# Provision these accounts in E0-12.

# Supabase (the project provides URL + keys)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string (Project Settings → Database) — used by the ingest job
# for fast vector upserts + ANALYZE. Looks like: postgresql://postgres:[pw]@[host]:5432/postgres
SUPABASE_DB_URL=

# Third-party API keys (server-only — NEVER in the extension bundle)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# TMDB: set EITHER the v4 read token (preferred) OR the v3 api key — both are on TMDB's API page.
TMDB_READ_TOKEN=
TMDB_API_KEY=

# Catalog ingest knobs (E1). Start small to validate, then raise INGEST_TARGET and re-run.
INGEST_TARGET=5000

# CORS allowlist: comma-separated chrome-extension://<id> origins
CORS_ALLOWED_ORIGINS=

# Cost guard (docs/09 §13 — caps × users ≤ budget is unit-test-enforced; see PRD §8)
MONTHLY_BUDGET_USD=5
EMBED_COST_CEILING_USD=3
BETA_MAX_USERS=10

# Observability + operator emails (optional; free tiers)
SENTRY_DSN=
RESEND_API_KEY=
OWNER_EMAIL=
